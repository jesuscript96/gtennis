# Backend env. Copy to .env (never commit). Production MUST run in an EU region.
SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=.onrender.com,localhost
DATABASE_URL=postgresql://user:pass@host:5432/gtenis   # EU Postgres
REDIS_URL=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=https://gtenis.vercel.app
# Sésame HR (leave blank to use the manual fallback)
SESAME_API_BASE=
SESAME_API_TOKEN=
